{
  "mcpServers": {
    "shodan": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bridge/shodan-server.cjs"],
      "env": {
        "SHODAN_API_KEY": "${SHODAN_API_KEY}"
      }
    },
    "sec": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bridge/security-tools-server.cjs"]
    },
    "hackerone": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bridge/hackerone-server.cjs"],
      "env": {
        "H1_API_TOKEN": "${H1_API_TOKEN}",
        "H1_USERNAME": "${H1_USERNAME}"
      }
    },
    "web": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bridge/web-tools-server.cjs"]
    }
  }
}
